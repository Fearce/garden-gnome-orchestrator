# Claude Orchestrator — server config
# Copy to .env. None of these are required for local use if your `claude` CLI
# is already logged in with your Max subscription.

# Subscription auth for headless / background-service use.
# Generate with:  claude setup-token   (1-year OAuth token, subscription-backed)
# Leave unset locally to inherit your logged-in Claude Code credentials.
CLAUDE_CODE_OAUTH_TOKEN=

# DO NOT set ANTHROPIC_API_KEY — it would route agents to metered API billing.
# The orchestrator deliberately runs on your subscription only.

# --- Multiple subscriptions (load-balance by burn ratio) ---
# Give each Claude sub its own long-lived token so the orchestrator can route
# each dispatch to whichever account has the most weekly headroom (and avoid
# 5h-throttled ones). One-time setup per account:
#   1) log into account A in Claude Code (`claude` then /login), run `claude setup-token`
#   2) paste the token below; repeat for account B logged into the other sub.
# With <2 tokens it runs single-account (just shows that account's burn bars).
# ACCOUNT_1_LABEL=personal
# ACCOUNT_1_TOKEN=
# ACCOUNT_2_LABEL=myaccount
# ACCOUNT_2_TOKEN=
# How often to ping each account for live 5h/weekly usage (tiny Haiku msg; also
# pinged right at each window reset regardless of this interval).
# ACCOUNT_PING_MS=600000
# USAGE_PING_MODEL=claude-haiku-4-5-20251001

# Server
PORT=4317
# Bind address. Keep 127.0.0.1 for localhost-only. For LAN/tablet access set this
# to 0.0.0.0 (or your LAN IP) — but ONLY with auth configured (AUTH_PASSWORD or Google);
# the server refuses to expose its bypassPermissions agents on the LAN unauthenticated.
HOST=127.0.0.1

# --- Access auth: a password and/or Google sign-in (both valid when set) ---
# Set EITHER or BOTH. A correct password OR a Google sign-in (allowlisted email) is a
# valid login; each mints the same signed httpOnly session cookie.

# Password — simplest, works everywhere INCLUDING the tablet over the raw LAN IP.
# A short PIN is safe because wrong attempts are rate-limited per client IP.
AUTH_PASSWORD=
# Wrong-password lockout per client IP, in ms (default 30000 = 30s).
# LOGIN_COOLDOWN_MS=30000

# Google sign-in — restricts to ALLOWED_EMAIL; silent when already signed into Google.
# Setup (once, ~3 min): https://console.cloud.google.com/apis/credentials
#   1) Create project → "OAuth client ID" → type "Web application".
#   2) Authorized redirect URIs: http://localhost:4317/api/auth/callback
#        AND http://127.0.0.1:4317/api/auth/callback
#      (Google allows http://localhost but REJECTS raw LAN IPs — so Google login only
#       works on the desktop unless you front it with an https hostname, e.g. Tailscale
#       *.ts.net, registered here + set as PUBLIC_ORIGIN. The tablet uses the password.)
#   3) Paste the client ID + secret below. ALLOWED_EMAIL defaults to the owner.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# ALLOWED_EMAIL=user@example.com
# Public origin Google redirects back to (https proxy / Tailscale). Leave unset for
# localhost dev. Pins the redirect_uri so it can't be spoofed via the Host header.
# PUBLIC_ORIGIN=https://your-host.tailnet.ts.net
# Secret to sign the session cookie (any strong random string).
# Defaults to GOOGLE_CLIENT_SECRET, else AUTH_PASSWORD.
# SESSION_SECRET=
# Optional webhook (e.g. a Discord webhook URL) pinged when a task needs you or
# finishes — so you get notified when you're away from the tab.
# NOTIFY_WEBHOOK_URL=

# Default repo the director offers when you don't specify one.
DEFAULT_WORKSPACE=C:\

# Path to the user's global memory dir (for the search_memory bridge).
MEMORY_DIR=C:\Users\user\.claude\memory
