# Claude Orchestrator — server config
# Copy to .env. None of these are required for local use if your `claude` CLI
# is already logged in with your Max subscription.

# Subscription auth for headless / background-service use.
# Generate with:  claude setup-token   (1-year OAuth token, subscription-backed)
# Leave unset locally to inherit your logged-in Claude Code credentials.
CLAUDE_CODE_OAUTH_TOKEN=

# DO NOT set ANTHROPIC_API_KEY — it would route agents to metered API billing.
# The orchestrator deliberately runs on your subscription only.

# --- Multiple subscriptions (load-balance by burn ratio) ---
# Give each Claude sub its own long-lived token so the orchestrator can route
# each dispatch to whichever account has the most weekly headroom (and avoid
# 5h-throttled ones). One-time setup per account:
#   1) log into account A in Claude Code (`claude` then /login), run `claude setup-token`
#   2) paste the token below; repeat for account B logged into the other sub.
# With <2 tokens it runs single-account (just shows that account's burn bars).
# ACCOUNT_1_LABEL=personal
# ACCOUNT_1_TOKEN=
# ACCOUNT_2_LABEL=vota
# ACCOUNT_2_TOKEN=
# How often to ping each account for live 5h/weekly usage (tiny Haiku msg; also
# pinged right at each window reset regardless of this interval).
# ACCOUNT_PING_MS=600000
# USAGE_PING_MODEL=claude-haiku-4-5-20251001

# Server
PORT=4317
# Bind address. Keep 127.0.0.1 for localhost-only. For LAN/tablet access set this
# to 0.0.0.0 (or your LAN IP) — but ONLY with AUTH_TOKEN set; the server refuses to
# expose its bypassPermissions agents on the LAN unauthenticated otherwise.
HOST=127.0.0.1
# Shared access token for LAN/tablet use (any strong random string). Unset = no auth (localhost only).
# AUTH_TOKEN=
# Optional webhook (e.g. a Discord webhook URL) pinged when a task needs you or
# finishes — so you get notified when you're away from the tab.
# NOTIFY_WEBHOOK_URL=

# Default repo the director offers when you don't specify one.
DEFAULT_WORKSPACE=C:\

# Path to Kevin's global memory dir (for the search_memory bridge).
MEMORY_DIR=C:\Users\theke\.claude\memory
